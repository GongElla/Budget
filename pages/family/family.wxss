.no-family {
  padding-top: 120rpx;
}

.action-btns {
  padding: 60rpx 40rpx;
}

.action-btns .btn-primary,
.action-btns .btn-secondary {
  margin-bottom: 24rpx;
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
}

.btn-secondary {
  background: var(--bg-white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.family-card {
  margin-bottom: 20rpx;
}

.family-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.family-name {
  font-size: 36rpx;
  font-weight: 600;
}

.family-role {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

.invite-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border);
}

.invite-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.invite-code {
  display: flex;
  align-items: center;
}

.invite-code text:first-child {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  margin-right: 16rpx;
  letter-spacing: 4rpx;
}

.copy-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.stats-card {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.stats-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #fa5151;
  margin-bottom: 24rpx;
}

.stats-detail {
  display: flex;
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
}

.stat-value.income {
  color: #07c160;
}

.stat-value.expense {
  color: #fa5151;
}

.category-stats,
.member-stats {
  margin-top: 32rpx;
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.cat-stat-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.cat-name {
  width: 120rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cat-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: var(--bg-primary);
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.cat-bar {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
}

.cat-amount {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-primary);
}

.member-stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.member-stat-item:last-child {
  border-bottom: none;
}

.members-card {
  margin-bottom: 20rpx;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.member-item:last-child {
  border-bottom: none;
}

.member-left {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: var(--bg-primary);
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.member-mode {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: var(--bg-primary);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
  align-self: flex-start;
}

.member-right {
  display: flex;
  align-items: center;
}

.creator-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-right: 12rpx;
}

.remove-btn {
  font-size: 24rpx;
  color: #fa5151;
  padding: 6rpx 16rpx;
  border: 1rpx solid #fa5151;
  border-radius: var(--radius-sm);
}

.member-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #fa5151;
}

.action-section {
  padding: 20rpx 0 40rpx;
}

.danger-btn {
  text-align: center;
  padding: 24rpx;
  color: #fa5151;
  font-size: 28rpx;
  background: var(--bg-white);
  border-radius: var(--radius-md);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  z-index: 201;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-input {
  height: 80rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--primary);
  color: #fff;
}
