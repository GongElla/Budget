.type-tabs {
  display: flex;
  background: var(--bg-white);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.amount-section {
  display: flex;
  align-items: center;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary);
  height: auto;
  min-height: 0;
}

.category-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
}

.category-row {
  border-bottom: 1rpx solid var(--border);
}

.category-row:last-child {
  border-bottom: none;
}

.category-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.category-left {
  display: flex;
  align-items: center;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-right: 20rpx;
}

.category-main.active .category-icon {
  background: var(--primary);
  color: #fff;
}

.category-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.category-main.active .category-name {
  color: var(--primary);
  font-weight: 600;
}

.check-mark {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 700;
  margin-right: 16rpx;
}

.subcategory-expand {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 0 24rpx 84rpx;
}

.subcategory-item {
  padding: 12rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.subcategory-item.active {
  background: var(--primary);
  color: #fff;
}

.subcategory-empty {
  padding: 0 0 24rpx 84rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.add-sub-link {
  color: var(--primary);
  font-size: 26rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
}

.add-sub-btn {
  background: var(--bg-primary);
  color: var(--primary);
  font-weight: 600;
  min-width: 56rpx;
  text-align: center;
  padding: 12rpx 16rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: 30rpx;
}

.modal-btn.cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--primary);
  color: #fff;
}

.info-section {
  margin-bottom: 40rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  width: 120rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: right;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: right;
  height: auto;
  min-height: 0;
}

.info-divider {
  height: 1rpx;
  background: var(--border);
}

.save-btn {
  margin: 0 20rpx;
}
